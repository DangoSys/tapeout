#!/bin/sh
set -eu

RUN_TAG="${RUN_TAG:-$(date +%m%d_%H%M)_buckyball_accel}"
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CONFIG_DIR=${CONFIG_DIR:-$PROJECT_ROOT/${CONFIG_DIR_NAME:-config}}
SYN_STAGE_DIR=${SYN_STAGE_DIR:-$SCRIPT_DIR}
export PROJECT_ROOT CONFIG_DIR SYN_STAGE_DIR
. "$CONFIG_DIR/env.sh"
cd "$SCRIPT_DIR"

mkdir -p alib-52 elab logs outputs rpt
rm -rf elab/*
mkdir -p "outputs/$RUN_TAG" "rpt/$RUN_TAG"

python3 ./scripts/sramReplace.py

LOG_FILE="logs/dc_${RUN_TAG}.log"
TOP_MODULE=BuckyballAccelerator \
CLOCK_PORT=clock \
CLOCK_NAME=clock \
dc_shell -f ./scripts/dc.tcl \
  -x "set RUN_TAG {$RUN_TAG}" \
  | tee "$LOG_FILE"

if grep -E "FATAL:|^Error:|Unable to resolve reference|has '[0-9]+' unresolved references|Cannot recover|Presto compilation terminated" "$LOG_FILE" >/dev/null; then
  echo "DC run reported fatal errors or unresolved references; see $LOG_FILE" >&2
  exit 1
fi
