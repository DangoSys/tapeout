#!/bin/sh
set -eu

RUN_TAG="${RUN_TAG:-$(date +%m%d_%H%M)}"
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "$SCRIPT_DIR/../config/env.sh"

mkdir -p alib-52 elab logs outputs rpt
rm -rf elab/*
mkdir -p "outputs/$RUN_TAG" "rpt/$RUN_TAG"

dc_shell -f ./scripts/dc.tcl -x "set RUN_TAG $RUN_TAG" | tee "logs/dc_${RUN_TAG}.log"
