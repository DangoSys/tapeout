#!/bin/sh
set -eu

RUN_TAG="${RUN_TAG:-$(date +%m%d_%H%M)}"
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CONFIG_DIR=${CONFIG_DIR:-$PROJECT_ROOT/${CONFIG_DIR_NAME:-config}}
POWER_STAGE_DIR=${POWER_STAGE_DIR:-$SCRIPT_DIR}
export PROJECT_ROOT CONFIG_DIR POWER_STAGE_DIR
. "$CONFIG_DIR/env.sh"
cd "$SCRIPT_DIR"

mkdir -p logs outputs rpt
mkdir -p "outputs/$RUN_TAG" "rpt/$RUN_TAG"

TOP_MODULE="${PTPX_TOP_MODULE:-BuckyballAccelerator}"
NETLIST_FILE="${PTPX_NETLIST_FILE:-$SCRIPT_DIR/netlist/${TOP_MODULE}.v}"
SDC_FILE="${PTPX_SDC_FILE:-$SCRIPT_DIR/netlist/${TOP_MODULE}.sdc}"
ACTIVITY_FILE="${PTPX_ACTIVITY_FILE:-$SCRIPT_DIR/waveform/glsim_mixed.saif}"
ACTIVITY_FORMAT="${PTPX_ACTIVITY_FORMAT:-saif}"
STRIP_PATH="${PTPX_STRIP_PATH:-tb_glsim_mixed/dut/chiptop0/system/tile_prci_domain/element_reset_domain_bbtile/accelerators_0}"

LOG_FILE="logs/ptpx_${RUN_TAG}.log"
TOP_MODULE="$TOP_MODULE" \
pt_shell -f ./scripts/ptpx.tcl \
  -x "set RUN_TAG {$RUN_TAG}; set PTPX_RUN_NETLIST_FILE {$NETLIST_FILE}; set PTPX_RUN_SDC_FILE {$SDC_FILE}; set PTPX_RUN_ACTIVITY_FILE {$ACTIVITY_FILE}; set PTPX_RUN_ACTIVITY_FORMAT {$ACTIVITY_FORMAT}; set PTPX_RUN_STRIP_PATH {$STRIP_PATH}" \
  | tee "$LOG_FILE"
